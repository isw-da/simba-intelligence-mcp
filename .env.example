# Simba Intelligence MCP environment variables.
# Copy to .env (or export in your shell) and fill in. Never commit a real key.

# Base URL for the Simba Intelligence host. Local default assumes the
# Caddy gateway documented in the SI setup skill (forwards /discovery and /api).
SI_BASE_URL=http://localhost:8080

# Static API key for the local instance, minted from the SI admin UI.
# Leave blank to fall back to username/password (then call authenticate()).
SI_API_KEY=

# Optional username/password fallback. Used by the authenticate() tool when no
# API key is set. The resulting bearer is cached in memory for the MCP session.
SI_USERNAME=
SI_PASSWORD=

# Request timeout in seconds.
SI_HTTP_TIMEOUT=60

# Composer context path under the SI host. SI bundles Composer behind
# `/discovery`; a standalone Composer install exposes `/composer`. The
# Composer admin, embed, and doc tools build URLs as
# `{SI_BASE_URL}{SI_COMPOSER_CONTEXT}/api/...`.
SI_COMPOSER_CONTEXT=/discovery
